{
  "name": "gptbot-ai-chat-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "GPTBot.uz AI Chat production backend (Railway). Fastify + Supabase + OpenRouter.",
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "node --import tsx --watch src/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "fastify": "^4.28.0",
    "jose": "^5.9.0",
    "pino": "^9.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
