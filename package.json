{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "tsx scripts/seo-audit.ts && tsc -b && vite build && tsx scripts/prerender.ts && tsx scripts/prerender-blog.ts && tsx scripts/prerender-home.ts && tsx scripts/generate-sitemap.ts && tsx scripts/generate-robots.ts && tsx scripts/generate-llm-markdown.ts",
    "build:fast": "vite build && tsx scripts/prerender.ts && tsx scripts/prerender-blog.ts && tsx scripts/prerender-home.ts && tsx scripts/generate-sitemap.ts && tsx scripts/generate-robots.ts && tsx scripts/generate-llm-markdown.ts",
    "build:cf": "tsx scripts/seo-audit.ts && vite build && tsx scripts/prerender.ts && tsx scripts/prerender-blog.ts && tsx scripts/prerender-home.ts && tsx scripts/generate-sitemap.ts && tsx scripts/generate-robots.ts && tsx scripts/generate-llm-markdown.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "seo:audit": "tsx scripts/seo-audit.ts",
    "seo:prerender": "tsx scripts/prerender.ts && tsx scripts/prerender-blog.ts",
    "seo:sitemap": "tsx scripts/generate-sitemap.ts",
    "seo:blog": "tsx scripts/apply-blog.ts --write && tsx scripts/prerender-blog.ts",
    "hash-password": "tsx scripts/hash-password.ts",
    "test:intent-guard": "node --import tsx --test tests/intent-guard.test.ts",
    "test:direct-generator": "node --import tsx --test tests/direct-generator.test.ts",
    "test:yandex-research": "node --import tsx --test tests/yandex-research.test.ts",
    "test": "node --import tsx --test tests/intent-guard.test.ts tests/direct-generator.test.ts tests/indexnow-engine.test.ts tests/yandex-research.test.ts tests/gpt-chat.test.ts tests/gpt-backend.test.ts tests/telegram-assistant.test.ts",
    "test:gpt-chat": "node --import tsx --test tests/gpt-chat.test.ts",
    "test:gpt-backend": "node --import tsx --test tests/gpt-backend.test.ts",
    "test:telegram": "node --import tsx --test tests/telegram-assistant.test.ts",
    "telegram:setup": "tsx scripts/telegram-setup.ts setup",
    "telegram:identity": "tsx scripts/telegram-setup.ts identity",
    "telegram:status": "tsx scripts/telegram-setup.ts status",
    "telegram:remove-webhook": "tsx scripts/telegram-setup.ts remove-webhook",
    "javob:eval": "tsx scripts/javob-eval.ts",
    "javob:eval:live": "tsx scripts/javob-eval.ts --live"
  },
  "dependencies": {
    "@base-ui-components/react": "^1.0.0-rc.0",
    "@floating-ui/react": "^0.27.20",
    "@fontsource-variable/geist": "^5.2.9",
    "@octokit/rest": "^22.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.16.0",
    "motion": "^12.42.2",
    "radix-ui": "^1.6.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260621.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "fast-glob": "^3.3.3",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "shadcn": "^4.13.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.22.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wrangler": "^4.103.0"
  }
}
