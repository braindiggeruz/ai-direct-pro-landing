# Example .env — copy to .env.local for local FastAPI dev mirror.
# PRODUCTION values are set in Cloudflare Pages → Settings → Environment variables.
# Never commit real secrets.

MONGO_URL="mongodb://localhost:27017"
DB_NAME="gptbot_dev"
CORS_ORIGINS="*"

# Auth (single admin)
ADMIN_EMAIL="admin@gptbot.uz"
# Generate with: yarn hash-password "<your-password>"
ADMIN_PASSWORD_HASH=""
# Optional dev fallback. DO NOT set in production.
# ADMIN_PASSWORD=""
JWT_SECRET="dev-only-jwt-secret-replace-in-prod-min-32-chars"

# GitHub (used by Cloudflare Functions to commit content)
GITHUB_TOKEN=""
GITHUB_OWNER="braindiggeruz"
GITHUB_REPO="ai-direct-pro-landing"
GITHUB_BRANCH="main"

# Optional
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
EMERGENT_LLM_KEY=""
