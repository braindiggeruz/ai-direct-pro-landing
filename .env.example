# Example .env — copy to .env.local for local FastAPI dev mirror.
# PRODUCTION values are set in Cloudflare Pages → Settings → Environment variables.
# Never commit real secrets.

MONGO_URL="mongodb://localhost:27017"
DB_NAME="gptbot_dev"
CORS_ORIGINS="*"

# Auth (single admin)
ADMIN_EMAIL="admin@gptbot.uz"
# Generate with: yarn hash-password "<your-password>"
ADMIN_PASSWORD_HASH=""
# Optional dev fallback. DO NOT set in production.
# ADMIN_PASSWORD=""
JWT_SECRET="dev-only-jwt-secret-replace-in-prod-min-32-chars"

# GitHub (used by Cloudflare Functions to commit content)
GITHUB_TOKEN=""
GITHUB_OWNER="braindiggeruz"
GITHUB_REPO="ai-direct-pro-landing"
GITHUB_BRANCH="main"

# Optional
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
# OpenRouter (AI-fill in admin editor) — server-side only, never reaches client bundle
OPENROUTER_API_KEY=""
OPENROUTER_MODEL_ECONOMY="openai/gpt-4o-mini"
OPENROUTER_MODEL_QUALITY="anthropic/claude-sonnet-4.5"
OPENROUTER_SITE_URL="https://gptbot.uz"
OPENROUTER_APP_TITLE="GPTBot SEO Cockpit"

# ─── Consumer AI-chat (/ru/gpt-chat/, /uz/gpt-uzbek-tilida/) ───
# Reuses OPENROUTER_API_KEY above. Model chains are comma-separated.
SITE_URL="https://gptbot.uz"
OPENROUTER_MODEL_FREE="nvidia/nemotron-3-nano-30b-a3b:free"
OPENROUTER_MODEL_FREE_FALLBACKS="qwen/qwen3-235b-a22b-2507:free,deepseek/deepseek-chat-v3-0324:free"
OPENROUTER_MODEL_PAID="mistralai/mistral-small-3.2-24b-instruct"
OPENROUTER_MODEL_PAID_FALLBACKS="meta-llama/llama-3.3-70b-instruct,deepseek/deepseek-chat"
GPT_FREE_DAILY_LIMIT="15"
GPT_FREE_HOURLY_LIMIT="5"
GPT_PAID_MONTHLY_LIMIT="600"
GPT_MAX_INPUT_CHARS="3000"
# SHA-256(CF-Connecting-IP + salt). Set a long random value in production.
GPT_HASH_SALT=""

# ─── Payments (subscription — scaffold only for MVP) ───
# PAYMENT_PROVIDER: lemonsqueezy | paddle | globalpay | freedompay | "" (manual)
PAYMENT_PROVIDER=""
PAYMENT_WEBHOOK_SECRET=""
LEMONSQUEEZY_API_KEY=""
PADDLE_API_KEY=""
GLOBALPAY_API_KEY=""
FREEDOMPAY_API_KEY=""
